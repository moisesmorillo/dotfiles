{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",
  "google_auth": false,
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "planner_enabled": false,
    "replace_plan": false
  },
  "agents": {
    "sisyphus": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "oracle": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "prometheus": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "metis": {
      "model": "zai/glm-5"
    },
    "atlas": {
      "model": "zai/glm-5"
    },
    "momus": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "explore": {
      "model": "zai/glm-4.7-flash"
    },
    "librarian": {
      "model": "zai/glm-5"
    },
    "multimodal-looker": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "deep": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "visual-engineering": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "artistry": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "quick": {
      "model": "zai/glm-4.7-flash"
    },
    "unspecified-low": {
      "model": "zai/glm-4.7-flash"
    },
    "unspecified-high": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "writing": {
      "model": "zai/glm-5"
    }
  }
}