{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini-fast",
  "autoupdate": false,
  "instructions": [
    "CLAUDE.md",
    "GEMINI.md"
  ],
  "default_agent": "plan",
  "agent": {
    "build": {
      "model": "openai/gpt-5.5"
    },
    "plan": {
      "model": "openai/gpt-5.5"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEX7_API_KEY}"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-smart-voice-notify@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-openai-codex-auth",
    "oh-my-openagent@latest"
  ],
  "enabled_providers": [
    "openai"
  ]
}
