{
  "$schema": "https://opencode.ai/config.json",
  "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "small_model": "zai/glm-5-turbo",
  "autoupdate": false,
  "instructions": [
    "CLAUDE.md",
    "GEMINI.md"
  ],
  "default_agent": "plan",
  "agent": {
    "build": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "plan": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEX7_API_KEY}"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ],
      "enabled": true
    },
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "opencode-smart-voice-notify@latest",
    "@tarquinen/opencode-dcp@latest"
  ],
  "enabled_providers": [
    "zai",
    "fireworks-ai"
  ],
  "provider": {
    "fireworks-ai": {
      "options": {
        "apiKey": "{env:FIREWORKS_AI_API_KEY}"
      }
    },
    "zai": {
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4"
      },
      "models": {
        "glm-5.1": {
          "id": "glm-5.1",
          "name": "GLM-5.1",
          "contextWindow": 204800,
          "maxTokens": 131072,
          "reasoning": true
        }
      }
    }
  }
}
